  "scripts": {
    "dev": "npm run db:start && npm run redis:start && npm run prisma:generate && cross-env NODE_ENV=development tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "db:start": "docker compose up -d db",
    "db:stop": "docker compose stop db",
    "redis:start": "docker compose up -d redis",
    "redis:stop": "docker compose stop redis",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
