# =========================================
# APP
# =========================================
NODE_ENV=development
PORT=5000
APP_NAME=my-backend
CLIENT_URL=http://localhost:3000

# =========================================
# DATABASE (PostgreSQL via Docker)
# =========================================
# ACTIVE: For native local development (npm run dev)
DATABASE_URL="postgres://root:rootpassword@localhost:5432/identityforge?schema=public"

# INACTIVE: Uncomment this for full Docker production (backend running INSIDE docker)
# DATABASE_URL="postgres://root:rootpassword@db:5432/identityforge?schema=public"

# =========================================
# AUTHENTICATION (JWT)
# =========================================
JWT_ACCESS_SECRET=supersecretaccesskey
JWT_REFRESH_SECRET=supersecretrefreshkey
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =========================================
# REDIS (Caching / Queues)
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================================
# EMAIL (SMTP)
# =========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@gmail.com
SMTP_PASS=password