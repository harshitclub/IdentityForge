# =========================================
# Base Image
# =========================================
FROM node:26-slim

# =========================================
# App Directory Inside Container
# =========================================
WORKDIR /app

# =========================================
# Copy package files
# =========================================
COPY package*.json ./

# =========================================
# Install Dependencies
# =========================================
RUN npm install

# =========================================
# Copy Source Code
# =========================================
COPY . .

# =========================================
# Build TypeScript
# =========================================
RUN npm run build

# =========================================
# Expose Port
# =========================================
EXPOSE 5000

# =========================================
# Start App
# =========================================
CMD ["npm", "run", "start"]